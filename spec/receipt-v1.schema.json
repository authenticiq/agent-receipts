{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:agent-receipts:schema:receipt:v1",
  "title": "agent-receipts receipt v1",
  "description": "A signed receipt for a single AI agent action. The signature covers the canonical JSON serialization of the payload object only.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "issued_at",
    "payload",
    "signature"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "agent-receipts/v1"
    },
    "receipt_id": {
      "$ref": "#/$defs/ulid"
    },
    "issued_at": {
      "type": "string",
      "format": "date-time",
      "description": "Timestamp recorded by the receipt issuer in RFC 3339 format."
    },
    "payload": {
      "$ref": "#/$defs/payload"
    },
    "signature": {
      "$ref": "#/$defs/signature"
    }
  },
  "$defs": {
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "description": "ULID in Crockford Base32, uppercase."
    },
    "sha256Digest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "sha512Digest": {
      "type": "string",
      "pattern": "^sha512:[a-f0-9]{128}$"
    },
    "contentDigest": {
      "oneOf": [
        {
          "$ref": "#/$defs/sha256Digest"
        },
        {
          "$ref": "#/$defs/sha512Digest"
        }
      ],
      "description": "Digest string in the form <algorithm>:<lowercase-hex>."
    },
    "eventType": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_.-]{1,63}$",
      "description": "Open vocabulary for the recorded action, for example tool_call or handoff."
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "id"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "agent",
            "human",
            "system"
          ]
        },
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Stable identifier for the acting principal within the issuer's trust domain."
        },
        "model": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional model identifier when the actor is an AI agent."
        },
        "session_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256,
          "description": "Optional session or run identifier."
        }
      }
    },
    "tool": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "transport"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128
        },
        "server": {
          "type": "string",
          "minLength": 1,
          "maxLength": 512,
          "description": "Identifier for the tool host or server. This may be a name, URI, or deployment identifier."
        },
        "transport": {
          "type": "string",
          "enum": [
            "mcp",
            "http",
            "local"
          ]
        }
      }
    },
    "payload": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "event_type",
        "actor",
        "tool",
        "inputs_hash",
        "outputs_hash"
      ],
      "properties": {
        "event_type": {
          "$ref": "#/$defs/eventType"
        },
        "actor": {
          "$ref": "#/$defs/actor"
        },
        "tool": {
          "$ref": "#/$defs/tool"
        },
        "inputs_hash": {
          "$ref": "#/$defs/contentDigest"
        },
        "outputs_hash": {
          "$ref": "#/$defs/contentDigest"
        },
        "parent_receipt_id": {
          "$ref": "#/$defs/ulid",
          "description": "Optional parent receipt identifier for causal lineage."
        }
      }
    },
    "signature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "alg",
        "key_id",
        "encoding",
        "value"
      ],
      "properties": {
        "alg": {
          "type": "string",
          "enum": [
            "ml-dsa-87",
            "ed25519"
          ]
        },
        "key_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 256
        },
        "encoding": {
          "type": "string",
          "const": "base64"
        },
        "value": {
          "type": "string",
          "pattern": "^(?:[A-Za-z0-9+/]{4})*(?:[A-Za-z0-9+/]{2}==|[A-Za-z0-9+/]{3}=)?$",
          "minLength": 8,
          "description": "Signature bytes encoded as RFC 4648 base64 with padding."
        }
      }
    }
  }
}